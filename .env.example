# Public canonical URL of the deployed site (used for SEO, sitemap, OG tags).
PUBLIC_SITE_URL="https://websitehistoryviewer.com"

# Optional: screenshot provider configuration (see src/services/screenshot.ts).
# Leave everything unset to use the built-in placeholder/iframe provider.
#
# Force a specific provider (otherwise `api` is auto-selected when
# SCREENSHOT_API_URL is set, else `placeholder`):
# SCREENSHOT_PROVIDER="api"
#
# External screenshot service. Renders the archived page to a real image used in
# previews AND Open Graph / Twitter social cards. Supports {url}, {width},
# {height}, {key} placeholders; if there's no {url}, the encoded target is
# appended as a query param (name via SCREENSHOT_API_PARAM, default "url").
#
# --- ScreenshotCore (https://screenshotcore.com/docs) ---
# Drop in your access key below; `api` is then auto-selected. jpeg keeps OG
# cards small and is supported by every social scraper.
# SCREENSHOT_API_URL="https://screenshotcore.com/api/v1/screenshot?url={url}&access_key={key}&viewport_width={width}&viewport_height={height}&format=jpeg"
# SCREENSHOT_API_KEY="your-screenshotcore-access-key"
#
# --- Generic example (any other provider) ---
# SCREENSHOT_API_URL="https://api.example.com/screenshot?url={url}&width={width}&token={key}"
# SCREENSHOT_API_PARAM="url"
