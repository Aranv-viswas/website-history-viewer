---
/**
 * GET /about — About Us. Static, prerendered. Explains what the project is,
 * how it works, and its relationship to the Internet Archive.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { breadcrumbJsonLd } from '@lib/seo';
import { getLang, localizePath } from '@i18n/utils';
import { getContent, fillTokens } from '@i18n/content';

const lang = getLang(Astro);
const c = getContent(lang).about;

const jsonLd = breadcrumbJsonLd([
  { name: 'Home', path: localizePath('/', lang) },
  { name: c.metaTitle, path: localizePath('/about', lang) },
]);
---

<BaseLayout title={c.metaTitle} description={c.metaDescription} jsonLd={jsonLd}>
  <article class="container-page py-12">
    <header class="mb-8 max-w-2xl">
      <p class="eyebrow">{c.eyebrow}</p>
      <h1
        class="mt-2 text-3xl font-semibold tracking-tighter text-neutral-900 sm:text-4xl dark:text-neutral-50"
      >
        {fillTokens(c.heading)}
      </h1>
    </header>

    <div
      class="prose prose-neutral max-w-2xl dark:prose-invert"
      set:html={fillTokens(c.bodyHtml)}
    >
    </div>
  </article>
</BaseLayout>
