---
/**
 * GET /contact — Contact Us. Static, prerendered. A simple mailto-based
 * contact page (no backend), plus the project's contact address.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { breadcrumbJsonLd } from '@lib/seo';
import { getLang, localizePath } from '@i18n/utils';
import { getContent, fillTokens } from '@i18n/content';

const lang = getLang(Astro);
const c = getContent(lang).contact;

const jsonLd = breadcrumbJsonLd([
  { name: 'Home', path: localizePath('/', lang) },
  { name: c.metaTitle, path: localizePath('/contact', lang) },
]);
---

<BaseLayout title={c.metaTitle} description={c.metaDescription} jsonLd={jsonLd}>
  <article class="container-page py-12">
    <header class="mb-8 max-w-2xl">
      <p class="eyebrow">{c.eyebrow}</p>
      <h1
        class="mt-2 text-3xl font-semibold tracking-tighter text-neutral-900 sm:text-4xl dark:text-neutral-50"
      >
        {c.heading}
      </h1>
      <p class="mt-3 text-neutral-600 dark:text-neutral-400">
        {c.sub}
      </p>
    </header>

    <div class="grid gap-8 lg:grid-cols-2" set:html={fillTokens(c.bodyHtml)}>
    </div>
  </article>
</BaseLayout>
