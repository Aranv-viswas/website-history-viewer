---
/**
 * Site header: brand, primary navigation, and a dark-mode toggle.
 * The toggle is the only interactive piece and uses a tiny inline script
 * (no framework island needed).
 */
import { POPULAR_SITES, LEGAL_PAGES } from '@lib/constants';
import {
  getLang,
  useTranslations,
  localizeHref,
  LOCALES,
  LANGUAGES,
} from '@i18n/utils';

const featured = POPULAR_SITES.slice(0, 5);

const lang = getLang(Astro);
const t = useTranslations(lang);
/** Localize an internal link to the active locale (tool routes stay canonical). */
const L = (path: string) => localizeHref(path, lang);
/** The current page in each locale, for the language switcher. */
const pathname = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 border-b border-neutral-200 bg-white/80 backdrop-blur-md dark:border-neutral-800 dark:bg-neutral-950/80"
>
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a
      href={L('/')}
      class="flex items-center gap-2 text-[15px] font-semibold tracking-tight text-neutral-900 dark:text-neutral-100"
    >
      <svg
        aria-hidden="true"
        viewBox="0 0 64 64"
        class="h-7 w-7 shrink-0"
      >
        <rect width="64" height="64" rx="14" class="fill-neutral-900 dark:fill-neutral-100" />
        <path
          transform="translate(12 12) scale(1.6667)"
          class="fill-white dark:fill-neutral-900"
          d="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"
        ></path>
      </svg>
      <span>Website History Viewer</span>
    </a>

    <nav
      class="hidden items-center gap-1 md:flex"
      aria-label="Primary"
    >
      <a
        href={L('/compare')}
        class="rounded-full px-3 py-1.5 text-sm text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
        >{t('nav.compare')}</a
      >
      <div class="group relative">
        <button
          type="button"
          class="rounded-full px-3 py-1.5 text-sm text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
          aria-haspopup="true"
        >
          {t('nav.histories')} ▾
        </button>
        <div
          class="invisible absolute right-0 top-full pt-1 opacity-0 transition group-hover:visible group-hover:opacity-100"
        >
          <div
            class="w-48 rounded-lg border border-neutral-200 bg-white p-1.5 shadow-float dark:border-neutral-800 dark:bg-neutral-900"
          >
          {
            featured.map((site) => (
              <a
                href={L(`/${site.domain.split('.')[0]}-history`)}
                class="block rounded-md px-3 py-2 text-sm text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
              >
                {site.emoji} {site.name}
              </a>
            ))
          }
          </div>
        </div>
      </div>
      <a
        href={L('/#facts')}
        class="rounded-full px-3 py-1.5 text-sm text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
        >{t('nav.internetHistory')}</a
      >
      <div class="group relative">
        <button
          type="button"
          class="rounded-full px-3 py-1.5 text-sm text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
          aria-haspopup="true"
        >
          {t('nav.more')} ▾
        </button>
        <div
          class="invisible absolute right-0 top-full pt-1 opacity-0 transition group-hover:visible group-hover:opacity-100"
        >
          <div
            class="w-48 rounded-lg border border-neutral-200 bg-white p-1.5 shadow-float dark:border-neutral-800 dark:bg-neutral-900"
          >
          {
            LEGAL_PAGES.map((page) => (
              <a
                href={L(page.href)}
                class="block rounded-md px-3 py-2 text-sm text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
              >
                {page.label}
              </a>
            ))
          }
          </div>
        </div>
      </div>

      {/* Language switcher — links to the current page in each locale. */}
      <div class="group relative">
        <button
          type="button"
          class="rounded-full px-3 py-1.5 text-sm text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
          aria-haspopup="true"
          aria-label={t('nav.language')}
        >
          {LANGUAGES[lang].flag} {LANGUAGES[lang].label} ▾
        </button>
        <div
          class="invisible absolute right-0 top-full pt-1 opacity-0 transition group-hover:visible group-hover:opacity-100"
        >
          <div
            class="w-44 rounded-lg border border-neutral-200 bg-white p-1.5 shadow-float dark:border-neutral-800 dark:bg-neutral-900"
          >
          {
            LOCALES.map((loc) => (
              <a
                href={localizeHref(pathname, loc)}
                hreflang={loc}
                aria-current={loc === lang ? 'true' : undefined}
                class:list={[
                  'block rounded-md px-3 py-2 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-800',
                  loc === lang
                    ? 'font-semibold text-neutral-900 dark:text-neutral-100'
                    : 'text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100',
                ]}
              >
                {LANGUAGES[loc].flag} {LANGUAGES[loc].label}
              </a>
            ))
          }
          </div>
        </div>
      </div>
    </nav>

    <button
      id="theme-toggle"
      type="button"
      class="flex h-9 w-9 items-center justify-center rounded-full border border-neutral-200 text-neutral-700 transition-colors hover:bg-neutral-100 dark:border-neutral-800 dark:text-neutral-200 dark:hover:bg-neutral-800"
      aria-label={t('nav.toggleTheme')}
    >
      <span class="hidden dark:inline" aria-hidden="true">☀️</span>
      <span class="inline dark:hidden" aria-hidden="true">🌙</span>
    </button>
  </div>
</header>

<script>
  // Persist and toggle the color theme.
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const isDark = root.classList.toggle('dark');
    try {
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    } catch (_) {
      /* ignore storage errors */
    }
  });
</script>
