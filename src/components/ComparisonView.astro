---
/**
 * ComparisonView — renders two snapshots in either "side by side" or "slider"
 * (before/after) mode.
 *
 *   - Mode switching is pure CSS using two named `peer` radios — no JS.
 *   - Side-by-side reuses <ScreenshotFrame> (two columns on desktop, stacked
 *     on mobile).
 *   - The slider overlays both previews and reveals the "before" layer with a
 *     draggable divider; only the drag handler is JS (interactive by nature).
 */
import type { ComparisonResult } from '@lib/types';
import ScreenshotFrame from '@components/ScreenshotFrame.astro';
import { placeholderPoster } from '@services/screenshot';

interface Props {
  result: ComparisonResult;
  labelA: string;
  labelB: string;
}

const { result, labelA, labelB } = Astro.props;
const { a, b } = result;

const posterA = placeholderPoster(labelA, a.screenshot.width, a.screenshot.height);
const posterB = placeholderPoster(labelB, b.screenshot.width, b.screenshot.height);
---

<div>
  {/* Mode switch (pure CSS via named peers) */}
  <input type="radio" name="cmp-mode" id="cmp-side" class="peer/side sr-only" checked />
  <input type="radio" name="cmp-mode" id="cmp-slide" class="peer/slide sr-only" />

  <div class="mb-5 inline-flex rounded-lg border border-neutral-300 p-1 dark:border-neutral-700">
    <label
      for="cmp-side"
      class="cursor-pointer rounded-md px-4 py-1.5 text-sm font-medium text-neutral-600 peer-checked/side:bg-brand-600 peer-checked/side:text-white dark:text-neutral-300"
      >Side by side</label
    >
    <label
      for="cmp-slide"
      class="cursor-pointer rounded-md px-4 py-1.5 text-sm font-medium text-neutral-600 peer-checked/slide:bg-brand-600 peer-checked/slide:text-white dark:text-neutral-300"
      >Slider</label
    >
  </div>

  {/* ---- Side-by-side mode ---- */}
  <div class="hidden peer-checked/side:grid grid-cols-1 gap-6 md:grid-cols-2">
    <div>
      <h3 class="mb-2 text-center text-sm font-semibold text-neutral-700 dark:text-neutral-300">
        {labelA}
      </h3>
      <ScreenshotFrame
        snapshot={a.snapshot}
        screenshot={a.screenshot}
        label={labelA}
        loading="eager"
        aspectClass="aspect-[16/10]"
      />
    </div>
    <div>
      <h3 class="mb-2 text-center text-sm font-semibold text-neutral-700 dark:text-neutral-300">
        {labelB}
      </h3>
      <ScreenshotFrame
        snapshot={b.snapshot}
        screenshot={b.screenshot}
        label={labelB}
        loading="eager"
        aspectClass="aspect-[16/10]"
      />
    </div>
  </div>

  {/* ---- Slider mode ---- */}
  <div class="hidden peer-checked/slide:block">
    {
      a.snapshot.available && b.snapshot.available ? (
        <div
          id="cmp-slider"
          class="relative aspect-[16/10] w-full select-none overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-800"
          style="--pos:50%"
        >
          {/* Bottom layer: B ("after") */}
          <div class="absolute inset-0">
            {b.screenshot.useIframe && b.screenshot.iframeUrl ? (
              <iframe
                src={b.screenshot.iframeUrl}
                title={`Archived ${labelB}`}
                referrerpolicy="no-referrer"
                sandbox="allow-scripts allow-same-origin"
                style={`background-image:url("${posterB}");background-size:cover;pointer-events:none;`}
                class="h-full w-full border-0"
              />
            ) : (
              <img src={b.screenshot.imageUrl ?? posterB} alt={b.screenshot.alt} class="h-full w-full object-cover object-top" />
            )}
          </div>

          {/* Top layer: A ("before"), clipped to the slider position */}
          <div
            class="absolute inset-0"
            style="clip-path: inset(0 calc(100% - var(--pos)) 0 0)"
          >
            {a.screenshot.useIframe && a.screenshot.iframeUrl ? (
              <iframe
                src={a.screenshot.iframeUrl}
                title={`Archived ${labelA}`}
                referrerpolicy="no-referrer"
                sandbox="allow-scripts allow-same-origin"
                style={`background-image:url("${posterA}");background-size:cover;pointer-events:none;`}
                class="h-full w-full border-0"
              />
            ) : (
              <img src={a.screenshot.imageUrl ?? posterA} alt={a.screenshot.alt} class="h-full w-full object-cover object-top" />
            )}
          </div>

          {/* Divider line + handle */}
          <div
            class="pointer-events-none absolute inset-y-0 z-10 w-0.5 -translate-x-1/2 bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.2)]"
            style="left: var(--pos)"
          >
            <span class="absolute top-1/2 left-1/2 flex h-9 w-9 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-white text-neutral-700 shadow">
              ⇄
            </span>
          </div>

          {/* Labels */}
          <span class="absolute top-2 left-2 z-10 rounded bg-black/60 px-2 py-0.5 text-xs font-medium text-white">{labelA}</span>
          <span class="absolute top-2 right-2 z-10 rounded bg-black/60 px-2 py-0.5 text-xs font-medium text-white">{labelB}</span>

          {/* Range input drives --pos */}
          <input
            id="cmp-range"
            type="range"
            min="0"
            max="100"
            value="50"
            aria-label="Comparison slider position"
            class="absolute inset-0 z-20 h-full w-full cursor-ew-resize opacity-0"
          />
        </div>
      ) : (
        <p class="rounded-xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-800 dark:border-amber-800 dark:bg-amber-950 dark:text-amber-200">
          Slider mode needs an available snapshot on both dates. Try the
          side-by-side view, or pick different dates.
        </p>
      )
    }
  </div>
</div>

<script>
  // Drive the slider clip position from the range input.
  const slider = document.getElementById('cmp-slider');
  const range = document.getElementById('cmp-range') as HTMLInputElement | null;
  if (slider && range) {
    const update = () => slider.style.setProperty('--pos', `${range.value}%`);
    range.addEventListener('input', update);
    update();
  }
</script>
