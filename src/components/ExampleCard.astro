---
/**
 * ExampleCard — a clickable popular-site example that links to the snapshot
 * viewer for a given domain + year (e.g. "Google 2005").
 */
import type { PopularSite } from '@lib/types';
import { domainToSlug } from '@utils/domain';
import { yearToISO } from '@utils/date';
import { getLang } from '@i18n/utils';
import { getContent } from '@i18n/content';

interface Props {
  site: PopularSite;
}

const { site } = Astro.props;
const href = `/site/${domainToSlug(site.domain)}/${yearToISO(site.year)}`;
const c = getContent(getLang(Astro));
---

<a
  href={href}
  class="card group flex flex-col gap-2 p-4 transition hover:border-neutral-300 hover:shadow-card-hover dark:hover:border-neutral-700"
>
  <div class="flex items-center justify-between">
    <span class="text-2xl" aria-hidden="true">{site.emoji ?? '🌐'}</span>
    <span
      class="rounded-full bg-neutral-100 px-2 py-0.5 font-mono text-xs font-medium text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300"
    >
      {site.year}
    </span>
  </div>
  <h3 class="font-semibold text-neutral-900 dark:text-neutral-100">
    {site.name} {site.year}
  </h3>
  {
    site.blurb && (
      <p class="text-sm text-neutral-500 dark:text-neutral-400">{site.blurb}</p>
    )
  }
  <span
    class="mt-auto pt-1 text-sm font-medium text-brand-600 group-hover:underline dark:text-brand-400"
  >
    {c.common.viewSnapshot}
  </span>
</a>
